# =============================================================================
# ops-timer 环境变量示例文件
# 复制此文件为 .env，填写真实值后再使用
# 注意：.env 已被 .gitignore 排除，请勿将含真实密钥的 .env 提交到版本库
# =============================================================================

# JWT 签名密钥（生产环境请使用强随机字符串，至少 32 位）
JWT_SECRET=change_me_to_a_random_secret_in_production

# SMTP 邮件发送
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password_or_app_token
SMTP_FROM=运维计时器 <noreply@example.com>

# OAuth / OIDC 单点登录（不启用时留空）
OAUTH_ENABLED=false
OAUTH_ISSUER_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/callback
OAUTH_FRONTEND_URL=http://localhost:5173

# 数据库（默认 SQLite，通常不需要修改）
# DB_DRIVER=sqlite
# DB_DSN=./data/timer.db
