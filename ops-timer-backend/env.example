# =============================================================================
# ops-timer-backend 环境变量模板（前缀 TIMER_，对应 config.yaml 中的嵌套键，点号改为下划线）
# 用法：复制为 .env 由 docker compose / 编排工具加载，或 export 后启动 ./opstimer
# 无 config.yaml 时仅靠这些变量即可运行；有配置文件时同名变量会覆盖文件中的值
# 列表类：多个值用英文逗号分隔（如 CORS、OAuth scopes、admin_emails）
# =============================================================================

# --- server ---
TIMER_SERVER_HOST=0.0.0.0
TIMER_SERVER_PORT=8080
# TIMER_SERVER_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- database ---
TIMER_DATABASE_DRIVER=sqlite
TIMER_DATABASE_DSN=./data/timer.db

# --- auth ---
TIMER_AUTH_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
TIMER_AUTH_JWT_EXPIRY_HOURS=24
TIMER_AUTH_LOGIN_LOCK_ATTEMPTS=5
TIMER_AUTH_LOGIN_LOCK_MINUTES=15

# --- scheduler ---
TIMER_SCHEDULER_NOTIFICATION_SCAN_INTERVAL=10m

# --- oauth / OIDC（不启用可保持 enabled=false 或留空 issuer/client 等）---
TIMER_OAUTH_ENABLED=false
# TIMER_OAUTH_ISSUER_URL=https://accounts.google.com
# TIMER_OAUTH_CLIENT_ID=
# TIMER_OAUTH_CLIENT_SECRET=
# TIMER_OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/callback
# TIMER_OAUTH_FRONTEND_URL=http://localhost:5173
# TIMER_OAUTH_SCOPES=openid,email,profile
# TIMER_OAUTH_ADMIN_EMAILS=admin@example.com,ops@example.com

# --- smtp（host 与 from 均非空时启用邮件；否则跳过）---
# TIMER_SMTP_HOST=smtp.example.com
TIMER_SMTP_PORT=587
# TIMER_SMTP_USERNAME=
# TIMER_SMTP_PASSWORD=
# TIMER_SMTP_FROM=运维计时器 <noreply@example.com>

# --- log ---
TIMER_LOG_LEVEL=info
TIMER_LOG_FORMAT=json
